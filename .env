# Environment configuration
ENVIRONMENT=development
LOG_LEVEL=INFO

# SQLite Configuration (Default: Active for running locally out-of-the-box!)
DATABASE_URL=sqlite+aiosqlite:///market_data.db
DATABASE_URL_SYNC=sqlite:///market_data.db

# PostgreSQL Database configuration (Used when DATABASE_URL is commented out)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=market_data
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis configuration (System falls back to In-Memory Queue automatically if Redis is offline)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USE_FALLBACK=true

# Market Data settings
API_POLL_INTERVAL_SECONDS=2.0
DEFAULT_SYMBOLS=BTC-USD,ETH-USD,SOL-USD,ADA-USD,DOGE-USD
